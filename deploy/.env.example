# JingWei 生产环境变量
# 复制为 /opt/jingwei/.env 并填入实际值

# 数据库
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jingwei
DB_USERNAME=jingwei
DB_PASSWORD=your_db_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# JWT 密钥（至少 256 位）
JWT_SECRET=replace_with_at_least_32_random_bytes_or_longer_secret
